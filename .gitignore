# Python bytecode and tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments and packaging output
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Local configuration and secrets
.env
.env.*
!.env.example
.python-version

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db
Desktop.ini

# Temporary output
*.tmp
*.temp
.tmp/
tmp/

# Raw local runs and research output
*.log
*.jsonl
*.ndjson
/research/
/local-research/
/external-operator-session-*/

# Internal development evidence; excluded from the first public tree
/staging/
/validation/
/dogfood/

# GDO runtime locks and temporary writes; not design content
**/.gdo/*.lock
**/.gdo/*.tmp

# Local Codex state, not the distributable skill package
.codex/
